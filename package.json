{
  "name": "discord-purge",
  "version": "0.0.0",
  "private": true,
  "description": "Bulk-unsend your own messages from Discord DMs.",
  "license": "GPL-3.0-only",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "tsx scripts/build.ts --target=chrome --watch",
    "build:chrome": "tsx scripts/build.ts --target=chrome && tsx scripts/pack-zip.ts",
    "build:firefox": "tsx scripts/build.ts --target=firefox && tsx scripts/pack-xpi.ts",
    "build:userscript": "tsx scripts/build.ts --target=userscript && tsx scripts/pack-userscript.ts",
    "build": "pnpm run build:chrome && pnpm run build:firefox && pnpm run build:userscript",
    "pack:chrome": "tsx scripts/pack-zip.ts",
    "pack:firefox": "tsx scripts/pack-xpi.ts",
    "pack:userscript": "tsx scripts/pack-userscript.ts",
    "pack": "pnpm run build",
    "icons": "tsx scripts/gen-icons.ts",
    "lint": "eslint . --max-warnings=0 && tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "prepare": "git config core.hooksPath .githooks || true"
  },
  "devDependencies": {
    "@types/archiver": "^8.0.0",
    "@types/chrome": "^0.2.2",
    "@types/firefox-webext-browser": "^143.0.0",
    "@types/node": "^26.1.1",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.59.2",
    "archiver": "^8.0.0",
    "esbuild": "^0.28.1",
    "eslint": "^10.7.0",
    "eslint-plugin-security": "^4.0.1",
    "globals": "^17.7.0",
    "prettier": "^3.9.5",
    "sass": "^1.101.0",
    "sharp": "^0.35.3",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3"
  },
  "allowScripts": {
    "@parcel/watcher@2.5.6": true,
    "esbuild@0.28.0": true,
    "sharp@0.34.5": true
  }
}
